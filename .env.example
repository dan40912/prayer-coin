# Copy this file to `.env` and adjust credentials as needed.
DATABASE_URL="mysql://root:root@localhost:3306/prayercoin_dev"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin session signing secret (use a long random string in every environment).
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Customer session signing secret (must be different from the admin secret).
CUSTOMER_SESSION_SECRET="replace-with-a-different-long-random-secret"

# Admin 2FA (TOTP) shared secret for current implementation.
# Generate a new secret per environment and enroll authenticator app again.
ADMIN_TOTP_SECRET="replace-with-totp-secret"

# Production media directories.
# Keep these outside the repo so deploys do not overwrite user uploads.
# VOICES_STORAGE_DIR="/home/startpraynow/prayer-coin-data/voices"
# UPLOADS_STORAGE_DIR="/home/startpraynow/prayer-coin-data/uploads"

# Optional fallback OTP for temporary testing only (do not enable in production).
# ADMIN_LOGIN_OTP="123456"

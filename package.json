{
  "name": "prayer-coin",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md,mjs}\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:admins": "node scripts/seed-admins.js",
    "qa": "node scripts/qa-flow.mjs",
    "qa:full": "node scripts/qa-flow.mjs full",
    "progress:sync": "python scripts/update_progress_tracker.py --event manual",
    "progress:commit": "python scripts/update_progress_tracker.py --event commit",
    "progress:push": "python scripts/update_progress_tracker.py --event push",
    "handoff:prepare": "python scripts/prepare_handoff.py"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-build-classic": "^39.0.2",
    "@ckeditor/ckeditor5-react": "^6.3.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "next": "^14.2.35",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.33.5",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "prettier": "^3.6.2"
  }
}
